{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/index.schema.json",
  "title": "Roadtrip Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "files",
    "days",
    "activity_index",
    "counts"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "trip_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "day",
          "title",
          "activity_ids",
          "attraction_ids",
          "place_ids",
          "knowledge_topic_ids",
          "missing_references"
        ],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "base": {
            "type": [
              "string",
              "null"
            ]
          },
          "overnight": {
            "type": [
              "string",
              "null"
            ]
          },
          "activity_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "optional_activity_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "choose_one_activity_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "attraction_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "place_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "knowledge_topic_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "missing_references": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "activity_index": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "status",
          "trip_day_refs",
          "attraction_ids",
          "place_ids",
          "knowledge_topic_ids"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "trip_day_refs": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "attraction_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "place_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "knowledge_topic_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "days",
        "activities",
        "attractions",
        "places",
        "knowledge_topics"
      ],
      "properties": {
        "days": {
          "type": "integer",
          "minimum": 0
        },
        "activities": {
          "type": "integer",
          "minimum": 0
        },
        "attractions": {
          "type": "integer",
          "minimum": 0
        },
        "places": {
          "type": "integer",
          "minimum": 0
        },
        "knowledge_topics": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}