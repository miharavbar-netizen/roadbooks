{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "accommodations"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "trip_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "accommodations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "location",
          "country",
          "nights",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "nights": {
            "type": "integer",
            "minimum": 1
          },
          "check_in": {
            "type": "string"
          },
          "check_out": {
            "type": "string"
          },
          "reception_hours": {
            "type": "string"
          },
          "total_price_eur": {
            "type": "number",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "booked",
              "cancelled",
              "completed"
            ]
          },
          "trip_days": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "booking_reference": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "google_maps_url": {
            "type": "string",
            "format": "uri"
          },
          "parking_note": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}