{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/places.schema.json",
  "title": "Roadtrip Places",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "places"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "trip_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "places": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/place"
      }
    }
  },
  "$defs": {
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lat",
        "lng"
      ],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-_]*$"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "parking",
            "restaurant",
            "cafe",
            "food_recommendation",
            "meeting_point",
            "visitor_center",
            "transport_node",
            "trailhead",
            "shop",
            "fuel",
            "pharmacy",
            "other"
          ]
        },
        "country": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "location_label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready",
            "archived"
          ]
        },
        "coordinates": {
          "$ref": "#/$defs/coordinates"
        },
        "google_maps_url": {
          "type": "string",
          "format": "uri"
        },
        "official_url": {
          "type": "string",
          "format": "uri"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "paid": {
          "type": "boolean"
        },
        "cuisine": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "roadbook_pick": {
          "type": "boolean"
        },
        "used_in_activity_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}