{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/knowledge.schema.json",
  "title": "Roadtrip Knowledge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topics"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "trip_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "topics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/topic"
      }
    }
  },
  "$defs": {
    "topic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-_]*$"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "history",
            "culture",
            "nature",
            "heritage",
            "geography",
            "religion",
            "politics",
            "architecture"
          ]
        },
        "summary": {
          "type": "string"
        },
        "key_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "used_in_activity_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "related_attraction_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "title",
              "url"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "official": {
                "type": "boolean"
              }
            }
          }
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}